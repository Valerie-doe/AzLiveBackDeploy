# Copy to .env and fill in values (never commit .env)

# Facebook OAuth / Webhooks
# En mode Développement, Meta autorise automatiquement http://localhost — pas besoin de l'ajouter dans le dashboard.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/facebook/callback/
FACEBOOK_LOGIN_SUCCESS_URL=http://localhost:3000/auth/facebook/success
FACEBOOK_WEBHOOK_VERIFY_TOKEN=azlive_secure_webhook_token_2026
FACEBOOK_WEBHOOK_FIELDS=feed,messages
# Requis si l'app est de type Entreprise (Facebook Login for Business)
FACEBOOK_CONFIG_ID=

# PostgreSQL
POSTGRES_DB=AZLive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/auth/tiktok/callback/
TIKTOK_LOGIN_SUCCESS_URL=http://localhost:3000/auth/tiktok/success
TIKTOK_OAUTH_SCOPES=user.info.basic

# URL publique pour les liens facture / étiquette dans les messages
AZLIVE_PUBLIC_BASE_URL=http://localhost:8000

# TikTools — https://tik.tools/dashboard
TIKTOOL_API_KEY=

# MediaMTX — diffusion « 1 clic » depuis le navigateur (WebRTC -> Facebook Live).
# Mettre à true une fois MediaMTX lancé (voir mediamtx/docker-compose.yml).
MEDIAMTX_ENABLED=false
# API de contrôle MediaMTX (provisioning des paths), vue depuis Django.
MEDIAMTX_API_URL=http://localhost:9997
# URL WHIP donnée au navigateur (HTTPS obligatoire en production / multi-machines).
MEDIAMTX_WHIP_BASE_URL=http://localhost:8889
# Hôte RTSP interne utilisé par ffmpeg pour relire le flux publié.
MEDIAMTX_RTSP_HOST=localhost:8554
# Encodage du relais ffmpeg vers Facebook (H.264 + AAC requis).
MEDIAMTX_FFMPEG_VIDEO_BITRATE=3000k
MEDIAMTX_FFMPEG_PRESET=veryfast
